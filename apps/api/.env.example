# MongoDB — single-node replica set (transactions require a replica set).
# directConnection=true avoids the advertised-host reconnect hang in local dev.
MONGODB_URI=mongodb://127.0.0.1:27017/micro_ats?replicaSet=rs0&directConnection=true

# HTTP
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# better-auth (generate a real secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=dev-only-change-me-please-32chars-min-000
BETTER_AUTH_URL=http://localhost:4000/api/auth

# Frontend origin (CORS + better-auth trustedOrigins)
WEB_ORIGIN=http://localhost:5200

# Booking guardrails
MIN_INTERVIEW_MINUTES=15
MAX_INTERVIEW_MINUTES=480
